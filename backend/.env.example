# MongoDB 数据库配置
MONGODB_URI=mongodb://localhost:27017/yun-jin-ku

# Session 配置
SESSION_SECRET=your-secret-key-here

# ============================================================
# 邮件服务配置（支持多邮箱轮换）
# ============================================================

# 方式一：单邮箱配置（兼容旧版）
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# 方式二：多邮箱配置（推荐）
# 当一个邮箱发送失败时，系统会自动切换到下一个邮箱重试
# 支持国内主流邮箱：QQ邮箱、163邮箱、126邮箱、新浪邮箱等

# QQ 邮箱配置
EMAIL_1_HOST=smtp.qq.com
EMAIL_1_PORT=587
EMAIL_1_USER=your-qq@qq.com
EMAIL_1_PASS=your-qq-authorization-code

# 163 邮箱配置
EMAIL_2_HOST=smtp.163.com
EMAIL_2_PORT=465
EMAIL_2_USER=your-163@163.com
EMAIL_2_PASS=your-163-authorization-code

# 126 邮箱配置（可选）
# EMAIL_3_HOST=smtp.126.com
# EMAIL_3_PORT=465
# EMAIL_3_USER=your-126@126.com
# EMAIL_3_PASS=your-126-authorization-code

# 新浪邮箱配置（可选）
# EMAIL_4_HOST=smtp.sina.com
# EMAIL_4_PORT=465
# EMAIL_4_USER=your-sina@sina.com
# EMAIL_4_PASS=your-sina-authorization-code

# Gmail 配置（可选，需要科学上网）
# EMAIL_5_HOST=smtp.gmail.com
# EMAIL_5_PORT=587
# EMAIL_5_USER=your-gmail@gmail.com
# EMAIL_5_PASS=your-gmail-app-password

# ============================================================
# 注意事项：
# 1. QQ邮箱、163邮箱等需要获取授权码，不是登录密码
# 2. QQ邮箱端口使用 587，163/126邮箱端口使用 465
# 3. 配置多个邮箱可以提高发送可靠性
# 4. 至少需要配置一个邮箱才能发送邮件
# ============================================================

# 前端地址
FRONTEND_URL=http://localhost:5173

# 端口
PORT=3001